+
+/* === 2026-03 UI refresh: clean sidebar + compact header + simple profile dropdown === */
+.topbar {
+  background: #f4f6fb !important;
+  padding: 4px 12px !important;
+  min-height: 52px;
+  box-shadow: 0 2px 10px rgba(15, 23, 42, 0.12) !important;
+}
+
+.header-identity {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+}
+
+.header-identity img {
+  width: 34px;
+  height: 34px;
+  border-radius: 999px;
+}
+
+.header-title {
+  margin: 0;
+  font-size: 0.98rem;
+  color: #1f2937;
+  font-weight: 700;
+}
+
+#sidebar .sidebar-head {
+  display: flex;
+  justify-content: center;
+  margin-bottom: 8px;
+}
+
+#sidebar .sidebar-logo-wrap img {
+  width: 44px !important;
+  height: 44px !important;
+  box-shadow: none;
+}
+
+#sidebar .sidebar-tree details,
+#sidebar .sidebar-tree summary,
+#sidebar .menu-btn {
+  background: transparent !important;
+  border: none !important;
+  box-shadow: none !important;
+}
+
+#sidebar .sidebar-tree summary,
