+}
+
+#sidebar .sidebar-tree summary:hover,
+#sidebar .menu-btn:hover,
+#sidebar .sidebar-tree details:hover > summary {
+  background: rgba(24, 119, 242, 0.14) !important;
+  color: #eaf3ff;
+}
+
+#sidebar .sidebar-tree summary .inline-menu-icon,
+#sidebar .menu-btn .inline-menu-icon {
+  color: #58a6ff;
+}
+
+#sidebar .sidebar-tree summary:hover .inline-menu-icon,
+#sidebar .menu-btn:hover .inline-menu-icon {
+  color: #8bc3ff;
+}
+
+#logged-in-view {
+  position: relative;
+  padding: 0 !important;
+}
+
+.profile-trigger {
+  width: 100%;
+  border: 0;
+  border-radius: 14px;
+  background: rgba(255, 255, 255, 0.09);
+  padding: 10px;
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  color: #fff;
+  cursor: pointer;
+}
+
+.user-role {
+  font-size: 0.76rem;
+  opacity: 0.82;
+}
+
+.profile-caret {
+  width: 16px;
+  height: 16px;
+  margin-left: auto;
+}
+
+.profile-dropdown {
+  display: none;
+  margin-top: 8px;
+  border-radius: 14px;
+  background: #111827;
+  border: 1px solid rgba(148, 163, 184, 0.2);
+  padding: 6px;
+}
+
+.profile-dropdown.show {
+  display: grid;
+  animation: dropdownFade .18s ease;
+}
+
+.profile-menu-item {
+  border: 0;
+  background: transparent;
+  color: #e5e7eb;
+  border-radius: 10px;
+  padding: 10px;
+  text-align: left;
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
